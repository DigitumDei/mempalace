ion":"Closet ID where this fact appears (optional)","type":"string"},"subject":{"description":"The entity doing/being something","type":"string"},"valid_from":{"description":"When this became true (YYYY-MM-DD, optional)","type":"string"}},"required":["subject","predicate","object"],"type":"object"},"name":"mempalace_kg_add"},{"description":"Mark a fact as no longer true. E.g. ankle injury resolved, job ended, moved house.","inputSchema":{"properties":{"ended":{"description":"When it stopped being true (YYYY-MM-DD, default: today)","type":"string"},"object":{"description":"Connected entity","type":"string"},"predicate":{"description":"Relationship","type":"string"},"subject":{"description":"Entity","type":"string"}},"required":["subject","predicate","object"],"type":"object"},"name":"mempalace_kg_invalidate"},{"description":"Chronological timeline of facts. Shows the story of an entity (or everything) in order.","inputSchema":{"properties":{"entity":{"description":"Entity to get timeline for (optional — omit for full timeline)","type":"string"}},"type":"object"},"name":"mempalace_kg_timeline"},{"description":"Knowledge graph overview: entities, triples, current vs expired facts, relationship types.","inputSchema":{"properties":{},"type":"object"},"name":"mempalace_kg_stats"},{"description":"Walk the palace graph from a room. Shows connected ideas across wings — the tunnels. Like following a thread through the palace: start at 'chromadb-setup' in wing_code, discover it connects to wing_myproject (planning) and wing_user (feelings about it).","inputSchema":{"properties":{"max_hops":{"description":"How many connections to follow (default: 2)","type":"integer"},"start_room":{"description":"Room to start from (e.g. 'chromadb-setup', 'riley-school')","type":"string"}},"required":["start_room"],"type":"object"},"name":"mempalace_traverse"},{"description":"Find rooms that bridge two wings — the hallways connecting different domains. E.g. what topics connect wing_code to wing